		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"gen-icons": "node scripts/gen-icons.mjs"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@lucide/svelte": "^1.17.0",
