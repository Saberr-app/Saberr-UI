		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"marked": "^18.0.5",
		"mode-watcher": "^1.1.0",
		"svelte-dnd-action": "^0.9.69",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0"
