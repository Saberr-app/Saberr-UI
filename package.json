{
	"name": "saberr-ui",
	"private": true,
	"version": "0.11.3",
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build-be": "node scripts/build-be.js",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
